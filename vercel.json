{
  "version": 2,
  "builds": [
    {
      "src": "api/solve.py",
      "use": "@vercel/python"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "style.css",
      "use": "@vercel/static"
    },
    {
      "src": "script.js",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/solve",
      "dest": "api/solve.py"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
